# Copy to `.env` and fill in secrets. Never commit a real `.env`.
# Defaults match Python-only PPT flow (SQLite + native generation unless you opt into bridge).

# Required for LLM-backed slide generation (leave empty to use heuristic-only decks).
# Name must be OPENAI_API_KEY (not OPEN_API_KEY). OPEN_API_KEY is also accepted as a typo alias.
OPENAI_API_KEY=

# Chat model (alias: OPENAI_MODEL also works).
OPENAI_CHAT_MODEL=gpt-4o-mini

# Optional: OpenAI-compatible base URL (default: https://api.openai.com/v1)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Unsplash API access key (native slide images: Unsplash first, Lorem Picsum fallback).
# Create an app at https://unsplash.com/oauth/applications and copy "Access Key".
# UNSPLASH_ACCESS_KEY=

# Agent-core SQLAlchemy URL (sessions/tools). Default is local SQLite if unset.
# Example Postgres:
# DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/ai_ppt?schema=public

# PPT: native = default (SQLite + in-process generation). bridge = proxy to TS on PPT_BACKEND_BASE_URL.
PPT_EXECUTION_MODE=native
PPT_NATIVE_DB_PATH=./agent_core_ppt_native.db

# PDF export: LibreOffice headless converts native PPTX → PDF (install LibreOffice; optional explicit binary).
# LIBREOFFICE_PATH=C:\Program Files\LibreOffice\program\soffice.exe
# PDF_EXPORT_TIMEOUT_SECONDS=120

# Legacy TypeScript backend (only with PPT_EXECUTION_MODE=bridge). `python run_api.py` forces native
# unless you set USE_TS_BRIDGE=1 before starting (see run_api.py / run_api.ps1 -Mode bridge).
# PPT_BACKEND_BASE_URL=http://localhost:4000/api/v1
